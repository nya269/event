# ===========================================
# OneLastEvent - Git Ignore
# ===========================================

# Dependencies
node_modules/

# Environment files (NEVER commit these!)
.env
.env.local
.env.*.local
.env.prod
.env.production
*.env

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
.next/
out/

# Coverage
coverage/
.nyc_output/

# IDE
.idea/
.vscode/
*.swp
*.swo
*.sublime-*

# OS
.DS_Store
Thumbs.db
*.orig

# Docker volumes (local data)
mysql_data/
redis_data/

# SSL Certificates (sensitive!)
certbot/
*.pem
*.key
*.crt

# Uploads (user content)
backend/uploads/*
!backend/uploads/.gitkeep

# Backend logs
backend/logs/*
!backend/logs/.gitkeep

# Test artifacts
*.test.js.snap
__snapshots__/

# Temporary files
*.tmp
*.temp
.cache/
