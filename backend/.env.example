# ============================================
# OneLastEvent - Configuration Production
# ============================================
# IMPORTANT: Copier ce fichier vers .env et remplir les valeurs
# Ne JAMAIS commiter le fichier .env avec des vraies valeurs!

# ============================================
# Application
# ============================================
NODE_ENV=production
PORT=4000
HOST=0.0.0.0
FRONTEND_URL=https://votre-domaine.com

# ============================================
# Base de données MySQL
# ============================================
DB_HOST=mysql
DB_PORT=3306
DB_USER=onevent_user
DB_PASS=CHANGER_MOT_DE_PASSE_FORT_32_CHARS
DB_NAME=onelastevent_db
DB_ROOT_PASSWORD=CHANGER_ROOT_PASSWORD_FORT

# ============================================
# Redis (Cache & Sessions)
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGER_REDIS_PASSWORD_FORT

# ============================================
# JWT Authentication
# IMPORTANT: Générer des secrets forts avec:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ============================================
JWT_ACCESS_SECRET=GENERER_SECRET_64_BYTES_MINIMUM
JWT_REFRESH_SECRET=GENERER_AUTRE_SECRET_64_BYTES_MINIMUM
JWT_ACCESS_EXP=15m
JWT_REFRESH_EXP=30d

# ============================================
# Stripe (Paiements)
# ============================================
STRIPE_SECRET_KEY=sk_live_VOTRE_CLE_STRIPE
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_WEBHOOK_SECRET

# ============================================
# Upload de fichiers
# ============================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ============================================
# Logging
# ============================================
LOG_LEVEL=info

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Email (SMTP) - Optionnel
# ============================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@votre-domaine.com
# SMTP_PASS=VOTRE_MOT_DE_PASSE_SMTP
# SMTP_FROM=OneLastEvent <noreply@votre-domaine.com>
