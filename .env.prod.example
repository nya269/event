# ===========================================
# OneLastEvent - PRODUCTION Environment
# ===========================================
# INSTRUCTIONS:
# 1. Copier ce fichier vers .env.prod
# 2. Remplir TOUTES les valeurs
# 3. Générer des secrets forts (voir commandes ci-dessous)
# 4. Ne JAMAIS commiter .env.prod!
# ===========================================

# Application
NODE_ENV=production
# Remplacer TON_IP_EC2 par l'IP publique de ton instance EC2 (ex: 54.123.45.67)
FRONTEND_URL=http://TON_IP_EC2
VITE_API_URL=http://TON_IP_EC2/api

# ===========================================
# Base de données MySQL
# Mots de passe forts: min 16 caractères, mélange majuscules/minuscules/chiffres/symboles
# ===========================================
DB_ROOT_PASSWORD=GENERER_PASSWORD_FORT_16_CHARS
DB_NAME=onelastevent_prod
DB_USER=onevent_prod_user
DB_PASS=GENERER_AUTRE_PASSWORD_FORT

# ===========================================
# Redis
# ===========================================
REDIS_PASSWORD=GENERER_REDIS_PASSWORD_FORT

# ===========================================
# JWT Secrets
# IMPORTANT: Générer avec cette commande:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ===========================================
JWT_ACCESS_SECRET=COPIER_ICI_LE_RESULTAT_DE_LA_COMMANDE_64_BYTES
JWT_REFRESH_SECRET=COPIER_ICI_UN_AUTRE_RESULTAT_64_BYTES
JWT_ACCESS_EXP=15m
JWT_REFRESH_EXP=30d

# ===========================================
# Stripe (Production)
# Obtenir sur: https://dashboard.stripe.com/apikeys
# ===========================================
STRIPE_SECRET_KEY=sk_live_VOTRE_CLE_PRODUCTION
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_WEBHOOK_SECRET_PRODUCTION

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
